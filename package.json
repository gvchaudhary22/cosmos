{
  "name": "@shiprocket/cosmos",
  "version": "1.0.0",
  "description": "COSMOS — AI Brain for Shiprocket ICRM. Orbit-powered orchestration, wave execution, and knowledge retrieval.",
  "main": "bin/cosmos.js",
  "bin": {
    "cosmos": "bin/cosmos.js"
  },
  "scripts": {
    "start":            ".venv/bin/uvicorn app.main:app --reload --port 10001",
    "start:grpc":       ".venv/bin/python app/grpc_server.py",
    "start:all":        ".venv/bin/uvicorn app.main:app --reload --port 10001 & .venv/bin/python app/grpc_server.py",

    "build":            "node bin/cosmos.js build",
    "build:kb":         ".venv/bin/python scripts/rocketmind_sync.py --target kb",
    "build:graph":      ".venv/bin/python scripts/rocketmind_sync.py --target graph",
    "build:all":        ".venv/bin/python scripts/rocketmind_sync.py --target all",

    "train":            ".venv/bin/python -c \"import asyncio; from app.services.training_pipeline import TrainingPipeline; print('Use /cosmos:train or POST /cosmos/api/v1/pipeline/run')\"",
    "train:kb":         "node bin/cosmos.js train --source kb",
    "train:code":       "node bin/cosmos.js train --source code",
    "train:eval":       "node bin/cosmos.js eval",

    "eval":             "node bin/cosmos.js eval",
    "eval:bench":       ".venv/bin/python scripts/run_eval.py",

    "sync":             ".venv/bin/python scripts/rocketmind_sync.py",
    "sync:agents":      ".venv/bin/python scripts/rocketmind_sync.py --target agents",
    "sync:skills":      ".venv/bin/python scripts/rocketmind_sync.py --target skills",
    "sync:workflows":   ".venv/bin/python scripts/rocketmind_sync.py --target workflows",

    "cosmos:new":       "node bin/cosmos.js cmd new-project",
    "cosmos:plan":      "node bin/cosmos.js cmd plan",
    "cosmos:build":     "node bin/cosmos.js cmd build",
    "cosmos:verify":    "node bin/cosmos.js cmd verify",
    "cosmos:ship":      "node bin/cosmos.js cmd ship",
    "cosmos:next":      "node bin/cosmos.js cmd next",
    "cosmos:quick":     "node bin/cosmos.js cmd quick",
    "cosmos:riper":     "node bin/cosmos.js cmd riper",
    "cosmos:forge":     "node bin/cosmos.js cmd forge",
    "cosmos:review":    "node bin/cosmos.js cmd review",
    "cosmos:audit":     "node bin/cosmos.js cmd audit",
    "cosmos:debug":     "node bin/cosmos.js cmd debug",
    "cosmos:resume":    "node bin/cosmos.js cmd resume",
    "cosmos:progress":  "node bin/cosmos.js cmd progress",
    "cosmos:state":     "node bin/cosmos.js cmd state",
    "cosmos:help":      "node bin/cosmos.js cmd help",

    "test":             ".venv/bin/python -m pytest tests/ -x -q --tb=short",
    "test:watch":       ".venv/bin/python -m pytest tests/ -x -q --tb=short -f",
    "test:coverage":    ".venv/bin/python -m pytest tests/ --cov=app --cov-report=term-missing",

    "lint":             ".venv/bin/ruff check app/ tests/",
    "lint:fix":         ".venv/bin/ruff check app/ tests/ --fix",
    "format":           ".venv/bin/ruff format app/ tests/",
    "typecheck":        ".venv/bin/mypy app/ --ignore-missing-imports",

    "health":           "curl -s http://localhost:10001/cosmos/health | python -m json.tool",
    "state":            "curl -s http://localhost:10001/cosmos/api/v1/cmd/state | python -m json.tool",
    "agents":           "curl -s http://localhost:10001/cosmos/api/v1/cmd/agents | python -m json.tool",
    "skills":           "curl -s http://localhost:10001/cosmos/api/v1/cmd/skills | python -m json.tool",

    "setup":            "bash scripts/setup.sh",
    
    "validate":         "bash scripts/validate.sh",
    "generate":         "node bin/cosmos.js generate"
  },
  "keywords": [
    "ai-brain",
    "cosmos",
    "rocketmind",
    "shiprocket",
    "icrm",
    "rag",
    "knowledge-graph",
    "rocketmind",
    "orchestration",
    "wave-execution"
  ],
  "author": "Shiprocket AI Platform",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "vitest": "^4.1.2"
  }
}
