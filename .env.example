# =============================================================================
# COSMOS (RocketMind) — Environment Configuration
# =============================================================================
#
# DATA FLOW OVERVIEW:
#
#   LIME (React :3003)
#     └─► MARS (Go :8080)  ←── SSO / Auth / Session / Routing
#           └─► COSMOS (Python :10001)  ←── AI Brain (THIS SERVICE)
#                 ├─► Claude Opus 4.6      (via AI Gateway)   — LLM inference
#                 ├─► text-embedding-3-small (via AI Gateway)  — vector embed
#                 ├─► Qdrant (:6333)                           — vector store
#                 ├─► Neo4j  (:7687)                           — knowledge graph
#                 ├─► MySQL  (:3309)                           — sessions / audit
#                 ├─► Kafka  (:9094)                           — event streaming
#                 └─► S3     (ap-southeast-1)                  — KB / exports
#
# QUERY EXECUTION PIPELINE:
#   Query → Claude QI (query intelligence) → 5-leg parallel retrieval
#   → RRF Fusion → Wave 2/3/4 (deep graph) → Claude reranking
#   → MMR diversity → Lost-in-middle prevention → Citation markup
#   → RALPH self-correction → HallucinationGuard → Response
#
# HOW TO USE:
#   cp .env.example .env
#   Fill in all REQUIRED values (marked with <REQUIRED>)
#   Optional values have sane defaults — only override if needed
#
# =============================================================================


# =============================================================================
# 1. SERVICE
#    COSMOS FastAPI service identity and runtime mode
# =============================================================================

PORT=10001
ENV=development                   # development | staging | production
LOG_LEVEL=info                    # debug | info | warning | error


# =============================================================================
# 2. LLM / AI — Claude via AI Gateway
#
#    FLOW:  COSMOS → AI Gateway (shiprocket) → Claude API (Anthropic)
#
#    LLM_MODE controls how Claude is invoked:
#      "api"    → direct Anthropic API (uses ANTHROPIC_API_KEY)
#      "cli"    → local `claude` binary (Claude Max plan, no API cost)
#      "hybrid" → cli for long reasoning, api for short classify tasks
#
#    Model routing (app/clients/):
#      Haiku  → intent classification, routing decisions   (1x cost)
#      Sonnet → code gen, test writing, standard tasks     (5x cost)
#      Opus   → KB content gen, graph schema, security     (25x cost)
# =============================================================================

LLM_MODE=cli                      # api | cli | hybrid
ANTHROPIC_API_KEY=<REQUIRED_IF_LLM_MODE=api>

# AI Gateway — proxies to OpenAI (embeddings) and Anthropic (LLM)
AIGATEWAY_API_KEY=<REQUIRED>
AIGATEWAY_URL=https://aigateway.shiprocket.in
AIGATEWAY_EMBEDDING_MODEL=text-embedding-3-small
AIGATEWAY_PROVIDER=openai

# OpenAI direct API — fallback when AI Gateway rate limit is hit
OPENAI_API_KEY=<REQUIRED>         # text-embedding-3-small (1536d) for Qdrant

# Voyage AI — alternative embeddings (optional)
VOYAGE_API_KEY=

# Model IDs (change only on major Claude releases)
LLM_MODEL_HAIKU=claude-haiku-4-5-20251001
LLM_MODEL_SONNET=claude-sonnet-4-6
LLM_MODEL_OPUS=claude-opus-4-6
LLM_TIMEOUT=30

# Cost Governance — hard stops to prevent runaway spend
COST_DAILY_BUDGET_USD=50.0        # Absolute daily ceiling across all sessions
COST_SESSION_BUDGET_USD=1.0       # Per-session cap before degraded mode


# =============================================================================
# 3. QDRANT — Vector Store
#
#    FLOW:  KB Doc → text-embedding-3-small → 1536d vector → Qdrant
#           Query  → text-embedding-3-small → cosine search → top-K chunks
#
#    Used in: Wave 1 Leg 4 (vector similarity search)
#    Collection schema: { id, vector[1536], payload: { pillar, entity_id,
#                         trust_score, query_mode, chunk_text, ... } }
# =============================================================================

QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=cosmos_embeddings


# =============================================================================
# 4. NEO4J — Knowledge Graph
#
#    FLOW:  KB Doc → graph node → edges to related pillars → traversal
#
#    Used in:
#      Wave 1 Leg 1 — exact entity lookup (entity_lookup table)
#      Wave 1 Leg 2 — Personalized PageRank (NetworkX seeds)
#      Wave 1 Leg 3 — BFS graph neighborhood (adaptive depth)
#      Wave 4       — Weighted Dijkstra (strongest relationship paths)
#
#    Node types: table, api_endpoint, action, workflow, page, module
#    Edge types: reads_table, uses_action, triggers_workflow, maps_to_page
# =============================================================================

NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<REQUIRED>


# =============================================================================
# 5. MYSQL — MARS Relational Database
#
#    FLOW:  COSMOS → MySQL (MARS DB) for:
#      - Sessions, conversation history, audit log
#      - KB ingestion state (what's been embedded, content hashes)
#      - Feedback loop records (low-confidence traces → staged improvements)
#      - Analytics (confidence scores, retrieval hit rates)
#
#    Wave 1 Leg 5: lexical search via MySQL LIKE + keyword matching
#    Wave 5 RIPER: reads eval benchmark seeds (201 ICRM eval cases)
#
#    Connection pool: max 10 + 5 overflow = 15 total; recycle every 30 min
# =============================================================================

DATABASE_URL=mysql+aiomysql://root:<PASSWORD>@127.0.0.1:3309/mars
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_RECYCLE=1800
DATABASE_POOL_PRE_PING=true
DATABASE_TIMEOUT=30

# Direct MySQL params (used by non-SQLAlchemy clients)
MARS_DB_HOST=127.0.0.1
MARS_DB_PORT=3309
MARS_DB_USER=root
MARS_DB_PASSWORD=<REQUIRED>
MARS_DB_NAME=mars

# Production Slave DB — read-only, for Tier 3 safe live DB queries
# Used by brain/tools when COSMOS needs to verify live order/shipment data
PROD_SLAVE_DB_HOST=slave-dr.shiprocket.in
PROD_SLAVE_DB_PORT=3306
PROD_SLAVE_DB_USERNAME=<REQUIRED>
PROD_SLAVE_DB_PASSWORD=<REQUIRED>
PROD_SLAVE_DB_NAME=multichannel
PROD_SLAVE_POOL_SIZE=5
PROD_SLAVE_MAX_OVERFLOW=2


# =============================================================================
# 6. KAFKA — Event Streaming
#
#    FLOW:  Shiprocket services → Kafka topics → COSMOS consumer group
#
#    COSMOS consumes:
#      sc_webhook_orders_wc  — WooCommerce order events (channel sync)
#      cosmos-workers group  — distributes load across COSMOS replicas
#
#    Used for:
#      - Real-time KB invalidation (order status changes)
#      - Async feedback ingestion (operator corrections)
#      - Training data collection (interaction traces)
#
#    Security: SASL_PLAINTEXT + SCRAM-SHA-512 for staging/prod
#              PLAINTEXT for local dev
# =============================================================================

KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=kafka-inhouse.shiprocket-stage-internal.in:9094
KAFKA_CONSUMER_GROUP=cosmos-workers
KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT  # PLAINTEXT for local dev
KAFKA_SASL_MECHANISM=SCRAM-SHA-512      # PLAIN for local dev
KAFKA_CLUSTER_USERNAME=<REQUIRED>
KAFKA_CLUSTER_PASSWORD=<REQUIRED>

# Kafka topic bindings
KAFKA_TOPIC_ORDERS_WC=sc_webhook_orders_wc


# =============================================================================
# 7. S3 — Object Storage
#
#    FLOW:  KB YAMLs ←→ S3 (sync) → local KB_PATH → ingestion pipeline
#                                   → Qdrant (embeddings)
#                                   → Neo4j (graph nodes)
#
#    Three distinct S3 prefixes (never mix them):
#      S3_KB_PREFIX             — source KB YAML files (read + write)
#      S3_TRAINING_PREFIX       — DPO/SFT training export files (write)
#      S3_EMBEDDING_BACKUP_PREFIX — Qdrant snapshot backups (write)
#
#    S3_ENABLED is auto-set to True when S3_BUCKET is non-empty
# =============================================================================

AWS_ACCESS_KEY_ID=<REQUIRED>
AWS_SECRET_ACCESS_KEY=<REQUIRED>
AWS_REGION=ap-southeast-1
S3_BUCKET=<REQUIRED>                              # e.g. ku-multichannel
S3_KB_PREFIX=knowledge_base/shiprocket
S3_TRAINING_PREFIX=cosmos/training-exports
S3_EMBEDDING_BACKUP_PREFIX=cosmos/embedding-backups


# =============================================================================
# 8. KNOWLEDGE BASE — Local File Path
#
#    FLOW:  S3 sync → KB_PATH (local disk) → ingestion pipeline
#
#    KB_PATH is the root of the 8-repo knowledge base tree:
#      KB_PATH/MultiChannel_API/   — P1–P8, 44,094 YAML files
#      KB_PATH/SR_Web/             — P1,P4,P5
#      KB_PATH/MultiChannel_Web/   — P1,P4,P5
#      KB_PATH/shiprocket-channels/
#      KB_PATH/helpdesk/
#      KB_PATH/shiprocket-go/
#      KB_PATH/sr_login/
#      KB_PATH/SR_Sidebar/
#
#    KB_SYNC_ENABLED: scheduler watches KB_PATH for file changes
#    KB_SYNC_BATCH_SIZE: files processed per scheduler tick
#    KB_SYNC_INTERVAL_SECONDS: how often to scan for changes (default 5min)
# =============================================================================

KB_PATH=/path/to/marsproject/mars/knowledge_base/shiprocket
KB_SYNC_ENABLED=true
KB_SYNC_BATCH_SIZE=100
KB_SYNC_INTERVAL_SECONDS=300


# =============================================================================
# 9. MARS BACKEND — Go Service Bridge
#
#    FLOW:  COSMOS → MARS (Go :8080) for:
#      - Session token validation (auth middleware)
#      - User context enrichment (company_id, role, permissions)
#      - Forwarding structured actions (execute order cancel, etc.)
#      - Hinglish pre-translation (MARS normalizes before COSMOS sees it)
#
#    MARS_BRIDGE_ENABLED: when false, COSMOS runs standalone (local dev)
#    HINGLISH_ENABLED: expect pre-translated English input from MARS
# =============================================================================

MARS_BASE_URL=http://localhost:8080
MARS_TIMEOUT=30.0
MARS_BRIDGE_ENABLED=true
HINGLISH_ENABLED=true


# =============================================================================
# 10. MCAPI — MultiChannel API (Shiprocket Backend)
#
#    FLOW:  COSMOS → MCAPI (apiv2.shiprocket.in) for:
#      - Live order/shipment data (Tier 3 DB query fallback)
#      - Action execution (cancel order, reattempt pickup, etc.)
#      - Channel data (WooCommerce, Shopify, Amazon sync status)
#
#    MCAPI_AUTH_MODE:
#      "user_jwt"      — forwards user's JWT from session (default)
#      "service_token" — COSMOS acts as service account (for async jobs)
# =============================================================================

MCAPI_BASE_URL=https://apiv2.shiprocket.in
MCAPI_AUTH_MODE=user_jwt
MCAPI_SERVICE_TOKEN=                  # Only needed for service_token auth mode
MCAPI_TIMEOUT=10
MCAPI_RATE_LIMIT=100


# =============================================================================
# 11. FEATURE FLAGS
#
#    FF_DRY_RUN         — log actions but don't execute (safe testing mode)
#    FF_PROMPT_SAFETY   — run guardrails on every LLM call (never disable prod)
#    FF_TOKEN_ECONOMICS — enforce cost budgets and token limits
# =============================================================================

FF_DRY_RUN=false
FF_PROMPT_SAFETY=true
FF_TOKEN_ECONOMICS=true


# =============================================================================
# 12. REDIS — Session Cache (optional)
#
#    FLOW:  COSMOS → Redis for:
#      - Conversation context window (last N turns per session)
#      - Rate limiting (per-user, per-session token budgets)
#      - Short-lived query result cache (< SESSION_TTL seconds)
#
#    Not critical for core RAG pipeline — COSMOS degrades gracefully
#    if Redis is unavailable (falls back to in-memory LRU cache)
# =============================================================================

REDIS_URL=redis://localhost:6379/0
SESSION_TTL=1800                      # 30 min session window


# =============================================================================
# 13. ELASTICSEARCH — Legacy Lexical Search (optional)
#
#    FLOW:  Used as fallback for Wave 1 Leg 5 if MySQL lexical search
#           doesn't cover enough content. Lower priority than Neo4j + Qdrant.
#           May be deprecated once MySQL FTS covers all pillars.
# =============================================================================

ELASTICSEARCH_HOSTS=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
