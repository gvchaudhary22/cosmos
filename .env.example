# COSMOS Environment Configuration

# Service
PORT=8000
ENV=development
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cosmos
DATABASE_POOL_SIZE=20
DATABASE_TIMEOUT=30

# MCAPI
MCAPI_BASE_URL=https://apiv2.shiprocket.in
MCAPI_AUTH_MODE=user_jwt
MCAPI_SERVICE_TOKEN=
MCAPI_TIMEOUT=10
MCAPI_RATE_LIMIT=100

# Claude AI
ANTHROPIC_API_KEY=
CLAUDE_MODEL_HAIKU=claude-haiku-4-5-20251001
CLAUDE_MODEL_SONNET=claude-sonnet-4-6
CLAUDE_TIMEOUT=30

# Elasticsearch
ELASTICSEARCH_HOSTS=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# Redis
REDIS_URL=redis://localhost:6379/0
SESSION_TTL=1800

# Feature Flags
FF_DRY_RUN=false
FF_PROMPT_SAFETY=true
FF_TOKEN_ECONOMICS=true
